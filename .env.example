# Server
NODE_ENV=development
PORT=5000
LOG_LEVEL=info
TRUST_PROXY=1
JSON_BODY_LIMIT=1mb
COMPRESSION_THRESHOLD=1024
HTTP_REQUEST_TIMEOUT_MS=30000
HTTP_HEADERS_TIMEOUT_MS=35000
HTTP_KEEP_ALIVE_TIMEOUT_MS=5000
SHUTDOWN_TIMEOUT_MS=10000

# PostgreSQL
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/zoiko_mail?schema=public"

# JWT secrets (use strong random strings in production)
JWT_ACCESS_SECRET=change-me-access-secret-min-32-chars
JWT_REFRESH_SECRET=change-me-refresh-secret-min-32-chars
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Security
CORS_ORIGIN=http://localhost:3000
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100
AUTH_RATE_LIMIT_WINDOW_MS=900000
REGISTER_RATE_LIMIT_MAX=10
LOGIN_RATE_LIMIT_MAX=20
REFRESH_RATE_LIMIT_MAX=30
INVITATION_EXPIRES_IN_HOURS=72
ATTACHMENT_STORAGE_PATH=storage/attachments
ATTACHMENT_MAX_SIZE_BYTES=10485760
MAIL_SEND_WINDOW_MS=3600000
MAIL_MAX_RECIPIENTS_PER_WINDOW=100
BCRYPT_ROUNDS=12

# Test database (optional — defaults to DATABASE_URL with _test suffix)
# TEST_DATABASE_URL="postgresql://postgres:postgres@localhost:5432/zoiko_mail_test?schema=public"
